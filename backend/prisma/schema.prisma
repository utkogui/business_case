generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  ANALYST
}

enum ProjectComplexity {
  LOW
  MEDIUM
  HIGH
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum ContractType {
  CLT
  PJ
  PARTNER
  FREELANCER
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Area {
  id            String              @id @default(cuid())
  name          String              @unique
  description   String?
  color         String?
  isActive      Boolean             @default(true)
  professionals Professional[]
  allocations   ProjectAllocation[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Professional {
  id            String              @id @default(cuid())
  name          String
  email         String?             @unique
  roleTitle     String
  contractType  ContractType
  monthlyCost   Decimal             @db.Decimal(12, 2)
  monthlyHours  Decimal             @db.Decimal(10, 2)
  overheadRate  Decimal             @db.Decimal(10, 2)
  hourlyCost    Decimal             @db.Decimal(12, 2)
  isActive      Boolean             @default(true)
  areaId        String
  area          Area                @relation(fields: [areaId], references: [id])
  allocations   ProjectAllocation[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Project {
  id                       String              @id @default(cuid())
  name                     String
  client                   String
  projectType              String
  description              String?
  plannedRevenue           Decimal             @db.Decimal(14, 2)
  actualRevenue            Decimal?            @db.Decimal(14, 2)
  complexity               ProjectComplexity
  status                   ProjectStatus
  plannedStartDate         DateTime
  plannedEndDate           DateTime
  actualStartDate          DateTime?
  actualEndDate            DateTime?
  notes                    String?
  executiveConclusion      String?
  strategicProfitability   Int?
  strategicOrganization    Int?
  strategicClient          Int?
  strategicFuturePotential Int?
  strategicPortfolio       Int?
  allocations              ProjectAllocation[]
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
}

model ProjectAllocation {
  id                 String       @id @default(cuid())
  projectId          String
  professionalId     String
  areaId             String
  plannedHours       Decimal      @db.Decimal(10, 2)
  actualHours        Decimal      @db.Decimal(10, 2)
  hourlyCostSnapshot Decimal      @db.Decimal(12, 2)
  plannedCost        Decimal      @db.Decimal(14, 2)
  actualCost         Decimal      @db.Decimal(14, 2)
  notes              String?
  project            Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  professional       Professional @relation(fields: [professionalId], references: [id])
  area               Area         @relation(fields: [areaId], references: [id])
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([projectId])
  @@index([professionalId])
  @@index([areaId])
}
